# BitPredict v2 — Environment Variables (WBTC + Parimutuel)
# Copy this file to .env and fill in your values
# All address fields MUST be filled before running — no defaults

# ===== Server =====
JWT_SECRET=                              # REQUIRED — random 32+ char string
OPNET_NETWORK=testnet                    # testnet or mainnet
OPNET_RPC_BASE=https://testnet.opnet.org # mainnet: https://api.opnet.org
OPNET_SEED=                              # REQUIRED — 12-word mnemonic (chmod 600 .env!)
WBTC_TOKEN=                              # REQUIRED — WBTC OP-20 contract address
STAKING_VAULT_ADDRESS=                   # REQUIRED — StakingVault contract address
TREASURY_ADDRESS=                        # REQUIRED — Treasury contract address
ALLOWED_ORIGIN=https://bitpredict.club
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PORT=3456

# Gas fee tuning (optional)
GAS_SAT_FEE=10000                        # Gas fee in sats (increase for mainnet congestion)
PRIORITY_FEE=1000                        # Priority fee in sats
LOW_POOL_THRESHOLD=500000                # Pool balance alert threshold (sats)

# Protocol revenue
PROTOCOL_TREASURY_ADDRESS=               # Where to flush protocol fees
WITHDRAWAL_FEE_PCT=0.005                 # 0.5% withdrawal fee
PROTOCOL_FLUSH_THRESHOLD=10000           # Sats threshold for auto-flush

# ===== Frontend =====
VITE_OPNET_NETWORK=testnet               # Must match OPNET_NETWORK
VITE_OPNET_RPC_URL=https://testnet.opnet.org
VITE_CONTRACT_ADDRESS=                   # REQUIRED — PredictionMarket contract
VITE_TOKEN_ADDRESS=                      # REQUIRED — WBTC token address
VITE_TOKEN_PUBKEY=                       # REQUIRED — WBTC ML-DSA pubkey (0x...)
VITE_VAULT_ADDRESS=                      # REQUIRED — StakingVault address
VITE_VAULT_PUBKEY=                       # REQUIRED — Vault ML-DSA pubkey (0x...)
VITE_TREASURY_ADDRESS=                   # REQUIRED — Treasury address
VITE_TREASURY_PUBKEY=                    # REQUIRED — Treasury ML-DSA pubkey (0x...)
VITE_WBTC_POOL_ADDRESS=                  # REQUIRED — BTC pool address (deployer p2tr)
VITE_API_URL=https://bitpredict.club

# ===== Oracle Bot =====
ORACLE_CONTRACT_PUBKEY=                  # PriceOracle ML-DSA pubkey (0x...)
ORACLE_INTERVAL_BLOCKS=2
