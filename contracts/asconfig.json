{
    "targets": {
        "vault-debug": {
            "outFile": "build/StakingVault.wasm",
            "textFile": "build/StakingVault.wat",
            "use": ["abort=src/vault-index/abort"]
        },
        "vault-release": {
            "outFile": "build/StakingVault.wasm",
            "textFile": "build/StakingVault.wat",
            "use": ["abort=src/vault-index/abort"]
        },
        "oracle-debug": {
            "outFile": "build/PriceOracle.wasm",
            "textFile": "build/PriceOracle.wat",
            "use": ["abort=src/oracle-index/abort"]
        },
        "oracle-release": {
            "outFile": "build/PriceOracle.wasm",
            "textFile": "build/PriceOracle.wat",
            "use": ["abort=src/oracle-index/abort"]
        },
        "treasury-debug": {
            "outFile": "build/Treasury.wasm",
            "textFile": "build/Treasury.wat",
            "use": ["abort=src/treasury-index/abort"]
        },
        "treasury-release": {
            "outFile": "build/Treasury.wasm",
            "textFile": "build/Treasury.wat",
            "use": ["abort=src/treasury-index/abort"]
        },
        "wbtc-debug": {
            "outFile": "build/WBTC.wasm",
            "textFile": "build/WBTC.wat",
            "use": ["abort=src/wbtc-index/abort"]
        },
        "wbtc-release": {
            "outFile": "build/WBTC.wasm",
            "textFile": "build/WBTC.wat",
            "use": ["abort=src/wbtc-index/abort"]
        }
    },
    "options": {
        "transform": "@btc-vision/opnet-transform",
        "sourceMap": false,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "converge": true,
        "noAssert": false,
        "enable": [
            "sign-extension",
            "mutable-globals",
            "nontrapping-f2i",
            "bulk-memory",
            "simd",
            "reference-types",
            "multi-value"
        ],
        "runtime": "stub",
        "memoryBase": 0,
        "initialMemory": 1,
        "exportStart": "start",
        "use": []
    }
}
